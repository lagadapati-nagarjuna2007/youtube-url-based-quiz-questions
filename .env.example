# QuizTube AI - Environment Variables Template
# Copy this file to .env and fill in your keys:
# cp .env.example .env

# Express server port
PORT=8080

# Supabase Configurations (Backend Only - Render)
# IMPORTANT: Use the Service Role Key for backend operations so that it has full database access.
# NEVER expose the Service Role Key on the frontend or commit it to GitHub.
SUPABASE_URL=https://your-supabase-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Groq API Configurations (Whisper V3 & LLM Reasoning)
GROQ_API_KEY=gsk_your_groq_key_here

# NVIDIA NIM API Configurations (Nemotron & Llama 3.2 Vision)
NVIDIA_API_KEY=nvapi-your_nvidia_key_here
NVIDIA_MODEL=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning
